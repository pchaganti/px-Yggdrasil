{
  "name": "@chrisdudek/yg",
  "version": "4.0.2",
  "description": "Continuous architecture enforcement for AI-assisted development. Aspects, review, enforcement.",
  "type": "module",
  "bin": {
    "yg": "dist/bin.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "graph-schemas/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:external": "vitest run --config vitest.external.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "yggdrasil",
    "ai-agents",
    "architecture-enforcement",
    "code-review",
    "ai-governance",
    "cli",
    "developer-tools",
    "ai-coding"
  ],
  "author": "Krzysztof Dudek <me@chrisdudek.com>",
  "license": "MIT",
  "homepage": "https://github.com/krzysztofdudek/Yggdrasil#readme",
  "bugs": {
    "url": "https://github.com/krzysztofdudek/Yggdrasil/issues",
    "email": "me@chrisdudek.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krzysztofdudek/Yggdrasil.git",
    "directory": "source/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "semver": "^7.7.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
