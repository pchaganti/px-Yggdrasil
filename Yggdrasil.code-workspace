{
  "folders": [
    {
      "name": "Root",
      "path": ".",
    },
    {
      "name": "📜 Documentation",
      "path": "docs",
    },
    {
      "name": "🧱 Source: CLI",
      "path": "source/cli",
    },
  ],
  "settings": {
    "cSpell.words": [
      "bierner",
      "chrisdudek",
      "clinerules",
      "cursorrules",
      "davidanson",
      "dbaeumer",
      "Dudek",
      "esbenp",
      "Krzysztof",
      "krzysztofdudek",
      "mtimes",
      "ollama",
      "opencode",
      "prereqs",
      "qwen",
      "roocode",
      "tiktoken",
      "unapproved",
      "vitepress",
      "Vitest",
      "worktrees",
      "yggdrasil",
      "yzhang",
    ],
    "files.exclude": {
      "**/.git": true,
      "**/.DS_Store": true,
      "**/Thumbs.db": true,
    },
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "🔍 Repository: Check All",
        "type": "shell",
        "command": "scripts/repo-check.sh",
        "isBackground": false,
      },
      {
        "label": "📜 Documentation: Dev Server",
        "type": "shell",
        "command": "npm run dev",
        "options": {
          "cwd": "${workspaceFolder}/docs",
        },
        "isBackground": true,
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "group": "docs",
        },
        "group": "build",
      },
      {
        "label": "📜 Documentation: Build",
        "type": "shell",
        "command": "npm run build",
        "options": {
          "cwd": "${workspaceFolder}/docs",
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "group": "docs",
        },
        "group": "build",
      },
      {
        "label": "📜 Documentation: Preview",
        "type": "shell",
        "command": "npm run preview",
        "options": {
          "cwd": "${workspaceFolder}/docs",
        },
        "isBackground": true,
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "group": "docs",
        },
        "group": "build",
      },
    ],
  },
  "extensions": {
    "recommendations": [
      "streetsidesoftware.code-spell-checker",
      "EditorConfig.EditorConfig",
      "github.vscode-github-actions",
      "GitHub.vscode-pull-request-github",
      "yzhang.markdown-all-in-one",
      "bierner.markdown-mermaid",
      "MermaidChart.vscode-mermaid-chart",
      "DotJoshJohnson.xml",
      "redhat.vscode-yaml",
      "davidanson.vscode-markdownlint",
    ],
  },
}
