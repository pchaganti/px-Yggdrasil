// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`aspect-status: issue-message snapshots > approve --aspect X Scenario A (aspect-default draft) 1`] = `
{
  "next": "Promote to 'advisory' or 'enforced' in .yggdrasil/aspects/X/yg-aspect.yaml to activate.",
  "what": "Aspect 'X' has default status 'draft' — reviewer skipped on every node.",
  "why": "Draft aspects are dormant; no baseline written, no drift tracked.",
}
`;

exports[`aspect-status: issue-message snapshots > approve --aspect X Scenario B (per-node effective-draft) 1`] = `
{
  "next": "To activate X on Y, remove the draft override on own:Y, or raise its effective status via another channel.",
  "what": "Aspect 'X' resolves to effective status 'draft' on node 'Y' (overridden by own:Y). Reviewer skipped on this node.",
  "why": "Other nodes where X is non-draft are unaffected.",
}
`;

exports[`aspect-status: issue-message snapshots > approve --node Y (all aspects draft) 1`] = `
{
  "next": "Promote at least one effective aspect to 'advisory' or 'enforced' to enable approve on this node.",
  "what": "Every effective aspect on node 'Y' has status 'draft'. Reviewer skipped.",
  "why": "Draft aspects are dormant; no baseline written, no drift tracked.",
}
`;

exports[`aspect-status: issue-message snapshots > aspect-newly-active (advisory) 1`] = `
{
  "next": "yg log add --node Y --reason "..." && yg approve --node Y",
  "what": "Aspect 'X' is effective on node 'Y' with status 'advisory', but no reviewer baseline exists yet.",
  "why": "The reviewer has not judged this node against this aspect. A status flip from 'draft' to 'advisory', a new attach, or a freshly authored aspect produces this state. Advisory status does not skip this step — every active aspect needs an initial verdict before yg check can render its result. Status only affects how the verdict renders later.",
}
`;

exports[`aspect-status: issue-message snapshots > aspect-newly-active (enforced) 1`] = `
{
  "next": "yg log add --node Y --reason "..." && yg approve --node Y",
  "what": "Aspect 'X' is effective on node 'Y' with status 'enforced', but no reviewer baseline exists yet.",
  "why": "The reviewer has not judged this node against this aspect. A status flip from 'draft' to 'enforced', a new attach, or a freshly authored aspect produces this state. Advisory status does not skip this step — every active aspect needs an initial verdict before yg check can render its result. Status only affects how the verdict renders later.",
}
`;

exports[`aspect-status: issue-message snapshots > aspect-status-downgrade 1`] = `
{
  "next": "Either remove the explicit status on this attach site (let the cascade win), or raise the cascading source if you actually want to weaken the rule everywhere. See: yg knowledge read aspect-status.",
  "what": "Node 'billing/cancel' attaches aspect 'audit-log' with status 'advisory', but the aspect cascades onto this node with status 'enforced' from flow:billing-flow.",
  "why": "An explicit attach-site status cannot relax (downgrade) what already cascades — that would silently weaken enforcement.",
}
`;

exports[`aspect-status: issue-message snapshots > aspect-status-invalid 1`] = `
{
  "next": "Edit .yggdrasil/aspects/X/yg-aspect.yaml and set status to one of the three valid values. See: yg knowledge read aspect-status.",
  "what": "Aspect 'X' declares status: 'unstable' (not a valid value).",
  "why": "Status must be one of: draft, advisory, enforced.",
}
`;

exports[`aspect-status: issue-message snapshots > aspect-violation-advisory 1`] = `
{
  "next": "Optional: address the violation (see aspect-violation-enforced options) or accept the warning as known state.",
  "what": "Node 'Y' fails advisory aspect 'X'. Reviewer reason: too many params.",
  "why": "Advisory aspects render as warning — they do not block yg check, but the violation is recorded.",
}
`;

exports[`aspect-status: issue-message snapshots > aspect-violation-enforced 1`] = `
{
  "next": "Read .yggdrasil/aspects/X/content.md, fix the code, then yg approve --node Y. Alternatives: change the aspect content, demote the aspect to advisory (see knowledge), or apply yg-suppress with a documented reason (user must approve).",
  "what": "Node 'Y' fails enforced aspect 'X'. Reviewer reason: too many params.",
  "why": "Enforced aspects block yg check. Fix the violation or change the rule.",
}
`;

exports[`aspect-status: issue-message snapshots > implies-status-inherit-invalid 1`] = `
{
  "next": "Edit .yggdrasil/aspects/A/yg-aspect.yaml. Use 'strictest' (default — implied aspect promotes to implier's status if higher) or 'own-default' (implied aspect keeps its own aspect-default).",
  "what": "Aspect 'A' implies aspect 'B' with status_inherit: 'lax' (not a valid value).",
  "why": "status_inherit must be one of: strictest, own-default.",
}
`;
