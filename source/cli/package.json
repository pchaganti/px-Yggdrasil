{
  "name": "@chrisdudek/yg",
  "version": "4.4.0",
  "description": "Architecture rules your coding agent can't ignore. Written in Markdown, verified on every change, enforced in the agent's loop — not after on a PR. Works with Claude Code, Cursor, Copilot, Codex, Cline.",
  "type": "module",
  "bin": {
    "yg": "dist/bin.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "graph-schemas/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:external": "vitest run --config vitest.external.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.check.json"
  },
  "keywords": [
    "yggdrasil",
    "architecture-enforcement",
    "code-guardrails",
    "agentic-guardrails",
    "rule-engine",
    "agents-md",
    "claude-md",
    "claude-code",
    "ai-agents",
    "coding-agents",
    "ai-coding",
    "ai-assisted-development",
    "cli",
    "developer-tools"
  ],
  "author": "Krzysztof Dudek <me@chrisdudek.com>",
  "license": "MIT",
  "homepage": "https://github.com/krzysztofdudek/Yggdrasil#readme",
  "bugs": {
    "url": "https://github.com/krzysztofdudek/Yggdrasil/issues",
    "email": "me@chrisdudek.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krzysztofdudek/Yggdrasil.git",
    "directory": "source/cli"
  },
  "exports": {
    "./ast": {
      "import": "./dist/ast.js",
      "types": "./dist/ast.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5",
    "minisearch": "^7.2.0",
    "semver": "^7.7.4",
    "web-tree-sitter": "^0.26.8",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.0.1",
    "prettier": "^3.8.1",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
